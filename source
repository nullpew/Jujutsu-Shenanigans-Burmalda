	if val then
		Configuration:SetAttribute("SpeedValue", val)
	end
end)

local MaxDist = Variables.LockOnMaxDistance
local MaxAngle = Variables.LockOnAngle
local MaxDistExtended = MaxDist + 20

local function GetBestLockOnTarget()
	local Best = nil
	local BestAngle = MaxAngle
	local CamCFrame = Camera.CFrame
	local CamPos = CamCFrame.Position
	local CamLook = CamCFrame.LookVector
	local RootPos = RootPart.Position

	for _, v in Folders.Characters:GetChildren() do
		if v == Character or not v:IsA("Model") then continue end

		local TargetHumanoid = v:FindFirstChildOfClass("Humanoid")
		local TargetRoot = v:FindFirstChild("HumanoidRootPart")

		if not TargetHumanoid or not TargetRoot then continue end
		if TargetHumanoid.Health <= 0 then continue end

		local TargetPos = TargetRoot.Position
		if (TargetPos - RootPos).Magnitude > MaxDist then continue end

		local _, OnScreen = Camera:WorldToScreenPoint(TargetPos)
		if not OnScreen then continue end

		local Dot = (TargetPos - CamPos).Unit:Dot(CamLook)
		local Angle = math.deg(math.acos(math.clamp(Dot, -1, 1)))

		if Angle < BestAngle then
			BestAngle = Angle
			Best = TargetRoot
		end
	end

	return Best
end

local LockOn = AddOption("Lock On", "LockOn", nil, "Allows you to lock the camera to a target | Bind X")
table.insert(Connections, Configuration:GetAttributeChangedSignal("LockOn"):Connect(function()
	if Configuration:GetAttribute("LockOn") then
		local Target = GetBestLockOnTarget()
		if Target then
			Variables.LockOnTarget = Target
		else
			Configuration:SetAttribute("LockOn", false)
		end
	else
		Variables.LockOnTarget = nil
	end
end))

local LockOnOffset = Vector3.new(0, 1, 0)
table.insert(Connections, RunService.RenderStepped:Connect(function()
	if not Configuration:GetAttribute("LockOn") or not Variables.LockOnTarget then return end

	local TargetCharacter = Variables.LockOnTarget.Parent
	local TargetHumanoid = TargetCharacter and TargetCharacter:FindFirstChildOfClass("Humanoid")

	if not TargetHumanoid or TargetHumanoid.Health <= 0 then
		Variables.LockOnTarget = nil
		Configuration:SetAttribute("LockOn", false)
		return
	end

	if (Variables.LockOnTarget.Position - RootPart.Position).Magnitude > MaxDistExtended then
		Variables.LockOnTarget = nil
		Configuration:SetAttribute("LockOn", false)
		return
	end

	local TargetPos = Variables.LockOnTarget.Position + LockOnOffset
	local CamPos = Camera.CFrame.Position
	Camera.CFrame = CFrame.lookAt(CamPos, TargetPos)
end))

UserInputService.InputBegan:Connect(function(Input, GameProcessed)
	if GameProcessed then return end
	if Input.KeyCode == Enum.KeyCode.X then
		Configuration:SetAttribute("LockOn", not Configuration:GetAttribute("LockOn"))
	elseif Input.KeyCode == Enum.KeyCode.T then
		Burmalda.Enabled = not Burmalda.Enabled
	end
end)

LocalPlayer.CharacterAdded:Connect(function(NewCharacter)
	Character = NewCharacter
	Humanoid = NewCharacter:WaitForChild("Humanoid")
	RootPart = NewCharacter:WaitForChild("HumanoidRootPart")
	Variables.LockOnTarget = nil
	Configuration:SetAttribute("LockOn", false)
	Configuration:SetAttribute("Speed", false)
end)

CloseButton.Activated:Connect(function()
	Debris:AddItem(Burmalda, 0)
	for i in Configuration:GetAttributes() do
		Configuration:SetAttribute(i, false)
	end
	for _, v in Connections do
		if typeof(v) == "RBXScriptConnection" then
			v:Disconnect()
		end
	end
	Debris:AddItem(Configuration, 0)
end)

