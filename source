local Dragging = false
local DragStart = nil
local FrameStart = nil

Topbar.InputBegan:Connect(function(Input)
	if Input.UserInputType == Enum.UserInputType.MouseButton1 then
		Dragging = true
		DragStart = Input.Position
		FrameStart = Main.Position
	end
end)

Topbar.InputEnded:Connect(function(Input)
	if Input.UserInputType == Enum.UserInputType.MouseButton1 then
		Dragging = false
	end
end)

UserInputService.InputChanged:Connect(function(Input)
	if not Dragging or Input.UserInputType ~= Enum.UserInputType.MouseMovement then return end
	local Delta = Input.Position - DragStart
	Main.Position = UDim2.new(
		FrameStart.X.Scale,
		FrameStart.X.Offset + Delta.X,
		FrameStart.Y.Scale,
		FrameStart.Y.Offset + Delta.Y
	)
end)

local ESPName = "ESP_" .. UniqueID
local ESP = AddOption("ESP", "ESP", nil, "Highlights all players on the map")
table.insert(Connections, Configuration:GetAttributeChangedSignal("ESP"):Connect(function()
	if Configuration:GetAttribute("ESP") then
		for _, v in Folders.Characters:GetChildren() do
			if v ~= Character and v:IsA("Model") and v:FindFirstChild("Humanoid") and not v:FindFirstChild(ESPName) then
				local Highlight = Instance.new("Highlight")
				Highlight.Name = ESPName
				Highlight.Parent = v
			end
		end
		Connections.ESP = Folders.Characters.ChildAdded:Connect(function(Child)
			if Child ~= Character and Child:IsA("Model") and Child:FindFirstChild("Humanoid") then
				local Highlight = Instance.new("Highlight")
				Highlight.Name = ESPName
				Highlight.Parent = Child
			end
		end)
	else
		if Connections.ESP then
			Connections.ESP:Disconnect()
			Connections.ESP = nil
		end
		for _, v in Folders.Characters:GetChildren() do
			if v:IsA("Model") and v:FindFirstChild("Humanoid") then
				local h = v:FindFirstChild(ESPName)
				if h then h:Destroy() end
			end
		end
	end
end))

