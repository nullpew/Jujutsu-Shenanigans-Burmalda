		TooltipPadding.PaddingRight = UDim.new(0, 10)
		TooltipPadding.PaddingTop = UDim.new(0, 6)
		TooltipPadding.PaddingBottom = UDim.new(0, 6)
		TooltipPadding.Parent = Tooltip

		local TooltipCorner = Instance.new("UICorner")
