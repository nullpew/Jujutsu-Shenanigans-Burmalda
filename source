local BindColorRE = "(Bind%s*%S*)"
local function BuildTooltipText(Text)
	return Text:gsub(BindColorRE, '<font color="#55FF7F"><b>%1</b></font>')
end

local function AddOption(Name, RealName, Value, Info)
